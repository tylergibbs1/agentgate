{
	"name": "@grayhaven/agentgate",
	"version": "0.1.0",
	"description": "AgentGate SDK — resolve natural language intents to API calls",
	"license": "MIT",
	"repository": { "type": "git", "url": "https://github.com/tylergibbs1/agentgate", "directory": "packages/sdk" },
	"keywords": ["agentgate", "agents", "api", "sdk", "ai", "intent", "protocol"],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"agentgate": "./dist/cli/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": ["dist", "specs", "README.md"],
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"prepublishOnly": "cp -r ../../specs ./specs"
	},
	"dependencies": {
		"@grayhaven/agentgate-schema": "^0.1.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0"
	}
}
